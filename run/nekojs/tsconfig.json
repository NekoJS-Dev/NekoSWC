{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "moduleDetection": "force",
    "lib": [
      "ESNext"
    ],
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "typeRoots": [
      "./probe"
    ]
  },
  "include": [
    "startup_scripts/**/*",
    "server_scripts/**/*",
    "client_scripts/**/*",
    "common_scripts/**/*",
    "probe/**/*"
  ]
}